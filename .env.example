# Copy to .env and adjust for local development.
# .env is gitignored.

# DATABASE_URL=sqlite:////absolute/path/to/notebook.db

# Required in production (APP_ENV=production)
# SECRET_KEY=generate-a-long-random-string

# APP_ENV=dev
# SECURE_COOKIES=false
# LOG_LEVEL=INFO

# Bootstrap admin on first startup (both must be set)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me-to-a-strong-password

# GUEST_USERNAME=__guest__

# Comma-separated hostnames when behind a reverse proxy
# ALLOWED_HOSTS=localhost,127.0.0.1
